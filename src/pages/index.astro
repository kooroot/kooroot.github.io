---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { icons } from '../components/icons/index';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.show_tile)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout>
  <Hero />

  <!-- Featured Projects -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">Featured Projects</h2>
      <a href="/projects" class="text-accent text-sm hover:underline flex items-center gap-1">
        View all
        <span set:html={icons.arrow} />
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}`}
          tech_stack={project.data.tech_stack}
          github={project.data.github}
          category={project.data.category}
        />
      ))}
    </div>
  </section>

  <!-- About Preview -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="bg-secondary border border-border rounded-2xl p-8 md:p-12 fade-in-up">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">About Me</h2>
      <p class="text-text-secondary leading-relaxed mb-6 max-w-2xl">
        Passionate blockchain researcher and engineer with a focus on Ethereum Layer 2 solutions.
        My expertise lies in developing scalable blockchain solutions and conducting in-depth research on emerging blockchain technologies.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/about" class="px-5 py-2.5 bg-accent text-white rounded-lg text-sm font-medium hover:bg-accent/90 transition-colors flex items-center gap-2">
          Learn More
          <span set:html={icons.arrow} />
        </a>
        <a href="https://github.com/kooroot" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 bg-card border border-border text-text-primary rounded-lg text-sm font-medium hover:border-accent/50 transition-colors flex items-center gap-2">
          <span set:html={icons.github} />
          GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
