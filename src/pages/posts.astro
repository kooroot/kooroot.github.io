---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="All Posts" description="Blockchain research, development projects, and node operations by kooroot">
  <!-- Banner -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-secondary/50 to-transparent" />
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">All Posts</h1>
      <p class="text-text-secondary text-lg">
        Blockchain research, development projects, and node operations.
      </p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {sortedProjects.map((project) => (
        <PostCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}`}
          image={project.data.image}
          category={project.data.category}
          date={project.data.date}
          tech_stack={project.data.tech_stack}
        />
      ))}
    </div>
  </section>
</BaseLayout>
