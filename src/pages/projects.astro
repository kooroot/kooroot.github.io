---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const categories = [
  { name: 'Blockchain Research', icon: 'research' },
  { name: 'Blockchain Development', icon: 'dev' },
  { name: 'Blockchain Node Operation', icon: 'ops' },
] as const;

const categoryColors: Record<string, string> = {
  'Blockchain Research': 'text-cyan-400',
  'Blockchain Development': 'text-green-400',
  'Blockchain Node Operation': 'text-purple-400',
};
---

<BaseLayout title="Projects" description="Blockchain Research & Development Projects">
  <!-- Banner -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-secondary/50 to-transparent" />
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">Projects</h1>
      <p class="text-text-secondary text-lg max-w-2xl">
        DeFi protocols, prediction market systems, smart contract audits, on-chain analytics, and distributed node infrastructure — built across Ethereum, Solana, and multiple L2 networks.
      </p>
    </div>
  </section>

  <!-- Project Categories -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    {categories.map((cat) => {
      const projects = allProjects
        .filter((p) => p.data.category === cat.name && p.data.show_tile)
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

      return projects.length > 0 ? (
        <div class="mb-16 fade-in-up">
          <h2 class={`text-2xl font-bold mb-8 pb-4 border-b border-border flex items-center gap-3 ${categoryColors[cat.name]}`}>
            {cat.name}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
            {projects.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                href={`/projects/${project.id}`}
                tech_stack={project.data.tech_stack}
                github={project.data.github}
                dune={project.data.dune}
                category={project.data.category}
              />
            ))}
          </div>
        </div>
      ) : null;
    })}

    <!-- Research Focus -->
    <div class="mt-16 p-8 bg-secondary border border-border rounded-2xl fade-in-up">
      <h2 class="text-2xl font-bold text-text-primary mb-4">Research Focus & Future Direction</h2>
      <p class="text-text-secondary leading-relaxed mb-6">
        Currently focused on the intersection of prediction markets and on-chain data — building ML pipelines for market signals, DeFi trading automation, and cross-chain interoperability. Continuing research in L2 rollup optimization and smart contract security.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/about" class="px-5 py-2.5 bg-accent text-white rounded-lg text-sm font-medium hover:bg-accent/90 transition-colors">
          About Me
        </a>
        <a href="https://github.com/kooroot" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 bg-card border border-border text-text-primary rounded-lg text-sm font-medium hover:border-accent/50 transition-colors">
          GitHub
        </a>
        <a href="https://linktr.ee/kooroot" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 bg-card border border-border text-text-primary rounded-lg text-sm font-medium hover:border-accent/50 transition-colors">
          Linktree
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
