---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found">
  <section class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center">
      <h1 class="text-8xl md:text-9xl font-bold text-accent mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-text-primary mb-4">Page Not Found</h2>
      <p class="text-text-secondary mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/" class="px-5 py-2.5 bg-accent text-white rounded-lg text-sm font-medium hover:bg-accent/90 transition-colors">
          Home
        </a>
        <a href="/projects" class="px-5 py-2.5 bg-card border border-border text-text-primary rounded-lg text-sm font-medium hover:border-accent/50 transition-colors">
          Projects
        </a>
        <a href="/posts" class="px-5 py-2.5 bg-card border border-border text-text-primary rounded-lg text-sm font-medium hover:border-accent/50 transition-colors">
          Posts
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
