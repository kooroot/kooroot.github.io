---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('writing');
const byDateDesc = (a, b) => b.data.date.getTime() - a.data.date.getTime();

const published = all.filter((p) => !p.data.draft).sort(byDateDesc);
const planned = all.filter((p) => p.data.draft).sort(byDateDesc);

const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Writing"
  description="Standalone technical deep dives on DeFi protocols, prediction-market infrastructure, account abstraction, and blockchain security."
>
  <!-- Banner -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-secondary/50 to-transparent" />
    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">Writing</h1>
      <p class="text-text-secondary text-lg max-w-2xl">
        Standalone technical deep dives — protocol mechanics, attack surfaces, and infrastructure
        notes drawn from hands-on research and engineering.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 pb-20">
    {published.length > 0 && (
      <div class="space-y-4 mb-16">
        {published.map((post) => (
          <a
            href={`/writing/${post.id}`}
            class="group block bg-card border border-border rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/50 hover:shadow-xl"
          >
            <div class="flex items-baseline justify-between gap-4 mb-2">
              <h2 class="text-xl font-semibold text-text-primary group-hover:text-accent transition-colors">
                {post.data.title}
              </h2>
              <time class="text-text-muted text-xs whitespace-nowrap">{fmt(post.data.date)}</time>
            </div>
            <p class="text-text-secondary text-sm leading-relaxed mb-4">{post.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((t) => (
                <span class="px-2.5 py-1 bg-secondary border border-border rounded-md text-xs font-medium text-text-muted">
                  {t}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    )}

    {planned.length > 0 && (
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-6">
          Planned / In progress
        </h2>
        <div class="space-y-3">
          {planned.map((post) => (
            <div class="block bg-secondary/40 border border-dashed border-border rounded-2xl p-6 opacity-80">
              <div class="flex items-baseline justify-between gap-4 mb-2">
                <h3 class="text-lg font-medium text-text-secondary">{post.data.title}</h3>
                <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20 whitespace-nowrap">
                  Planned
                </span>
              </div>
              <p class="text-text-muted text-sm leading-relaxed mb-4">{post.data.description}</p>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((t) => (
                  <span class="px-2.5 py-1 bg-card border border-border rounded-md text-xs font-medium text-text-muted">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {published.length === 0 && planned.length === 0 && (
      <p class="text-text-muted">No writing published yet.</p>
    )}
  </section>
</BaseLayout>
