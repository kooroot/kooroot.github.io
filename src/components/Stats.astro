---
import { getCollection } from 'astro:content';
import { CERTIFICATIONS, YEARS_XP } from '../consts';

const allProjects = await getCollection('projects');
const projectCount = allProjects.filter((p) => p.data.show_tile).length;
const certCount = CERTIFICATIONS.length;

const stats = [
  { value: `${projectCount}`, label: 'Projects' },
  { value: YEARS_XP, label: 'Years XP' },
  { value: `${certCount}`, label: 'Certs' },
];
---

<div class="grid grid-cols-3 gap-4 md:gap-6 max-w-md">
  {stats.map((stat) => (
    <div class="text-center p-4 bg-card border border-border rounded-xl hover:-translate-y-0.5 transition-transform">
      <div class="text-2xl md:text-3xl font-bold text-accent mb-1">{stat.value}</div>
      <div class="text-xs text-text-muted">{stat.label}</div>
    </div>
  ))}
</div>
