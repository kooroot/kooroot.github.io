---
import { NAV_ITEMS, SITE } from '../consts';
import { icons } from './icons/index';

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-xl font-bold text-text-primary hover:text-accent transition-colors">
      {SITE.title}
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8">
      {NAV_ITEMS.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-accent',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'text-accent'
                : 'text-text-secondary',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="md:hidden text-text-primary hover:text-accent transition-colors"
      aria-label="Toggle menu"
    >
      <span id="menu-icon" set:html={icons.menu} />
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-primary/95 backdrop-blur-lg border-t border-border">
    <ul class="flex flex-col px-6 py-4 gap-4">
      {NAV_ITEMS.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block text-sm font-medium py-2 transition-colors hover:text-accent',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'text-accent'
                : 'text-text-secondary',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>
