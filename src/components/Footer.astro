---
import { SITE, SOCIALS } from '../consts';
import { icons } from './icons/index';
---

<footer class="border-t border-border mt-20">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      <!-- Info -->
      <div class="flex flex-col items-center md:items-start gap-2 text-text-muted text-sm">
        <div class="flex items-center gap-2">
          <span set:html={icons.mail} />
          <a href={`mailto:${SITE.email}`} class="hover:text-accent transition-colors">
            {SITE.email}
          </a>
        </div>
        <div class="flex items-center gap-2">
          <span set:html={icons.location} />
          <span>{SITE.location}</span>
        </div>
      </div>

      <!-- Social Links -->
      <div class="flex items-center gap-4">
        {SOCIALS.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-accent transition-colors"
            aria-label={social.name}
          >
            <span set:html={icons[social.icon as keyof typeof icons]} />
          </a>
        ))}
      </div>
    </div>

    <div class="text-center text-text-muted text-xs mt-8">
      &copy; {new Date().getFullYear()} {SITE.title}. All rights reserved.
    </div>
  </div>
</footer>
