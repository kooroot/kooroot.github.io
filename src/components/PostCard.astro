---
interface Props {
  title: string;
  description: string;
  href: string;
  image: string;
  category: string;
  date: Date;
  tech_stack: string[];
}

const { title, description, href, image, category, date, tech_stack } = Astro.props;

const categoryColors: Record<string, string> = {
  'Blockchain Research': 'bg-cyan-500/10 text-cyan-400',
  'Blockchain Development': 'bg-green-500/10 text-green-400',
  'Blockchain Node Operation': 'bg-purple-500/10 text-purple-400',
};
---

<a href={href} class="group block bg-card border border-border rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-accent/30">
  <!-- Image -->
  <div class="relative h-48 overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute top-3 left-3">
      <span class={`px-2.5 py-1 rounded-full text-xs font-medium ${categoryColors[category] || 'bg-accent/10 text-accent'}`}>
        {category}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-5">
    <h3 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-accent transition-colors line-clamp-1">
      {title}
    </h3>
    <p class="text-text-secondary text-sm leading-relaxed mb-3 line-clamp-2">
      {description}
    </p>
    <div class="flex flex-wrap gap-1.5 mb-3">
      {tech_stack.slice(0, 3).map((tech) => (
        <span class="px-2 py-0.5 bg-secondary border border-border rounded text-xs text-text-muted">
          {tech}
        </span>
      ))}
      {tech_stack.length > 3 && (
        <span class="px-2 py-0.5 text-xs text-text-muted">+{tech_stack.length - 3}</span>
      )}
    </div>
    <time class="text-xs text-text-muted" datetime={date.toISOString()}>
      {date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
  </div>
</a>
