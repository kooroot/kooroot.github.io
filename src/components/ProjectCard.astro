---
import { icons } from './icons/index';

interface Props {
  title: string;
  description: string;
  href: string;
  tech_stack: string[];
  github?: string;
  category: string;
}

const { title, description, href, tech_stack, github, category } = Astro.props;

const categoryBorders: Record<string, string> = {
  'Blockchain Research': 'hover:border-cyan-500/50 hover:shadow-cyan-500/5',
  'Blockchain Development': 'hover:border-green-500/50 hover:shadow-green-500/5',
  'Blockchain Node Operation': 'hover:border-purple-500/50 hover:shadow-purple-500/5',
};
---

<a
  href={href}
  class:list={[
    'group block bg-card border border-border rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl',
    categoryBorders[category] || 'hover:border-accent/50',
  ]}
>
  <h3 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-accent transition-colors">
    {title}
  </h3>
  <p class="text-text-secondary text-sm leading-relaxed mb-4 line-clamp-2">
    {description}
  </p>
  <div class="flex flex-wrap gap-2 mb-4">
    {tech_stack.map((tech) => (
      <span class="px-2.5 py-1 bg-secondary border border-border rounded-md text-xs font-medium text-text-muted">
        {tech}
      </span>
    ))}
  </div>
  {github && (
    <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-[#0F0F15] border border-border rounded-md text-xs font-medium text-text-muted group-hover:text-text-primary group-hover:border-accent/50 transition-colors">
      <span set:html={icons.github} class="w-4 h-4" />
      <span>GitHub</span>
    </div>
  )}
</a>
